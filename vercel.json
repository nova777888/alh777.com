{
  "version": 2,
  "builds": [
    {
      "src": "api/send-code.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/verify-code.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/login.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/register.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/me.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/reset-password.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/bind-email.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/me-dashboard.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/me-downlines.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/me-transactions.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/me-commissions.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/me/bind-referrer.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/send-code",
      "dest": "/api/send-code.js"
    },
    {
      "src": "/api/verify-code",
      "dest": "/api/verify-code.js"
    }
  ],
  "headers": [
    {
      "source": "/countries/nigeria/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
