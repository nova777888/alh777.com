{
  "version": 2,
  "builds": [
    {
      "src": "api/check-forgot-phone.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/send-code.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/verify-code.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/check-forgot-phone",
      "dest": "/api/check-forgot-phone.js"
    },
    {
      "src": "/api/send-code",
      "dest": "/api/send-code.js"
    },
    {
      "src": "/api/verify-code",
      "dest": "/api/verify-code.js"
    }
  ],
  "headers": [
    {
      "source": "/countries/nigeria/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
